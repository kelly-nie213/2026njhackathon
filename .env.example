# Copy to .env and fill in to enable the live Claude-powered features
# (AI phishing analyzer + personalized action plan). Without it, the app
# falls back to a built-in heuristic + the deterministic plan, so demos
# still work end to end.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: port for the API proxy (defaults to 8787; Vite proxies /api here)
# PORT=8787

# BreachDetector breach lookups use XposedOrNot (https://xposedornot.com) — a
# free public API that needs NO key. No config required; it's live by default.
# Optional: ms between breach-lookup requests to be polite (default 350)
# BREACH_DELAY_MS=350
